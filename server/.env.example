PORT=5000
MONGODB_URI=mongodb+srv://your_username:your_password@your-cluster.mongodb.net/hoavu_platform?retryWrites=true&w=majority&appName=HoaVu
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
TRUST_PROXY=1
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
# Upload provider: local | s3
UPLOAD_PROVIDER=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
AWS_S3_PUBLIC_BASE_URL=
AWS_S3_ENDPOINT=
